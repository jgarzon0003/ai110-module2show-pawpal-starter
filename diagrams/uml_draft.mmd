classDiagram
    %% Draft UML for PawPal+ based on brainstormed design.
    %% Keep this file updated so it matches your final implementation.

    class Owner {
        +str name
        +time available_start
        +time available_end
        +int max_minutes_per_day
        +get_available_minutes() int
    }

    class Pet {
        +str name
        +str species
        +List~Task~ tasks
        +add_task(task) None
    }

    class Task {
        +str title
        +str category
        +int duration_minutes
        +str priority
        +time start_time
        +str reason
        +mark_scheduled(start_time, reason) None
    }

    class Scheduler {
        +build_plan(owner, pet) List~Task~
        +sort_by_priority(tasks) List~Task~
        +assign_time_slots(owner, tasks) List~Task~
    }

    Owner "1" --> "1..*" Pet : owns
    Pet "1" --> "*" Task : has
    Scheduler ..> Owner : reads constraints
    Scheduler ..> Pet : reads tasks
    Scheduler --> Task : schedules
